# Sanity CMS (OPTIONAL - enables Studio and CMS-backed project content)
# Create a project at https://www.sanity.io/manage and copy the Project ID + dataset name.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Optional override if you need a fixed API version.
# NEXT_PUBLIC_SANITY_API_VERSION=2026-04-22

# Spotify Playlist ID (REQUIRED)
# Get this from a Spotify playlist URL: https://open.spotify.com/playlist/PLAYLIST_ID_HERE
# Or share a playlist and copy the ID from the share link
# Example: 37i9dQZF1DXcBWIGoYBM5M
NEXT_PUBLIC_SPOTIFY_PLAYLIST_ID=your_playlist_id_here

# Spotify API Credentials (OPTIONAL - for reliable artist names)
# Create an app at https://developer.spotify.com/dashboard → Settings → copy Client ID & Client Secret.
# No redirect URI or user auth needed; we only use the public tracks API (Client Credentials).
# SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Site gate (OPTIONAL)
# production (Vercel) defaults to under-construction empty screen after the boot loader.
# NEXT_PUBLIC_SITE_GATE=construction  # force on locally
# NEXT_PUBLIC_SITE_GATE=open          # force full site on production
